  "description": "ProShot Studio — AI Headshot Suite (TypeScript + Lit, plugin architecture)",
  "type": "module",
  "scripts": {
    "start": "web-dev-server --config web-dev-server.config.mjs",
    "build": "tsc --noEmit && rollup -c rollup.config.js",
